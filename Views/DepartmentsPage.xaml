<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PayrollManager.Views.DepartmentsPage"
             Title="الأقسام"
             BackgroundColor="#F8F9FA"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <Frame Grid.Row="0" CornerRadius="10" BorderColor="#E0E0E0" BackgroundColor="White" Margin="20,15,20,5" Padding="15">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAddDepartmentTapped" />
            </Frame.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Label Text="+" FontSize="20" FontAttributes="Bold" TextColor="#8A72D6" VerticalOptions="Center"/>
                <Label Text="إضافة قسم" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Frame>

        <ScrollView Grid.Row="1" Padding="20,5">
            <VerticalStackLayout Spacing="15">
                
                <Frame CornerRadius="12" BorderColor="#E0E0E0" BackgroundColor="White" Padding="15">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,15,0">
                            <Label Text="Main" FontSize="18" FontAttributes="Bold" TextColor="Black" HorizontalOptions="End"/>
                            <Label Text="Default main department" FontSize="14" TextColor="Gray" HorizontalOptions="End" Margin="0,2,0,0"/>
                        </VerticalStackLayout>
                        
                        <Image Source="dotnet_bot.png" WidthRequest="24" HeightRequest="24" Grid.Column="2" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>