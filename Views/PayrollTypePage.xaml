<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PayrollManager.Views.PayrollTypePage"
             Title="كشوف الرواتب"
             BackgroundColor="#F8F9FA">

    <!-- Main layout handling the list and the bottom export button cleanly -->
    <Grid RowDefinitions="*, Auto" Padding="20,10">

        <!-- Top Section: List of Payroll Types -->
        <ScrollView Grid.Row="0" VerticalOptions="StartAndExpand">
            <VerticalStackLayout Spacing="15">

                <!-- 1. Add Payroll Type Button Frame -->
                <Frame CornerRadius="10" BorderColor="#E0E0E0" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddPayrollTypeTapped" />
                    </Frame.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Label Text="+" FontSize="20" FontAttributes="Bold" TextColor="#8A72D6" VerticalOptions="Center"/>
                        <Label Text="إضافة كشف راتب" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- 2. Card: Main Payroll -->
                <Frame CornerRadius="12" BorderColor="#E0E0E0" BackgroundColor="White" Padding="15">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <ImageButton Source="dotnet_bot.png" WidthRequest="20" HeightRequest="20" Grid.Column="0" VerticalOptions="Center" Clicked="OnEditTapped"/>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,15,0">
                            <Label Text="Main" FontSize="18" FontAttributes="Bold" TextColor="Black" HorizontalOptions="End"/>
                            <Label Text="Default main payroll" FontSize="14" TextColor="Gray" HorizontalOptions="End" Margin="0,2,0,0"/>
                        </VerticalStackLayout>
                        <Image Source="dotnet_bot.png" WidthRequest="24" HeightRequest="24" Grid.Column="2" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <!-- 3. Card: Second Payroll -->
                <Frame CornerRadius="12" BorderColor="#E0E0E0" BackgroundColor="White" Padding="15">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <ImageButton Source="dotnet_bot.png" WidthRequest="20" HeightRequest="20" Grid.Column="0" VerticalOptions="Center" Clicked="OnEditTapped"/>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,15,0">
                            <Label Text="2" FontSize="18" FontAttributes="Bold" TextColor="Black" HorizontalOptions="End"/>
                            <Label Text="الثاني" FontSize="14" TextColor="Gray" HorizontalOptions="End" Margin="0,2,0,0"/>
                        </VerticalStackLayout>
                        <Image Source="dotnet_bot.png" WidthRequest="24" HeightRequest="24" Grid.Column="2" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Section: Export to Excel/CSV Button -->
        <Frame Grid.Row="1" CornerRadius="10" BorderColor="#E0E0E0" BackgroundColor="White" 
               Padding="12" HorizontalOptions="Center" WidthRequest="180" Margin="0,10,0,10">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnExportTapped" />
            </Frame.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Image Source="dotnet_bot.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center"/>
                <Label Text="تصدير Excel/CSV" FontSize="15" TextColor="#512BD4" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Frame>

    </Grid>
</ContentPage>