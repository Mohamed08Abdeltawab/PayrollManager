<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PayrollManager.Views.RevenuesPage"
             Title="الإيرادات"
             BackgroundColor="#F8F9FA">
    <!-- Custom Navigation Bar Actions -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="بحث" IconImageSource="dotnet_bot.png" Order="Primary" Clicked="OnSearchClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*" Padding="20,10">
        <ScrollView Grid.Row="0" VerticalOptions="StartAndExpand">
            <VerticalStackLayout Spacing="15">

                <!-- 1. Add Revenue Button Card -->
                <Frame CornerRadius="10" BorderColor="#E0E0E0" BackgroundColor="White" Padding="12">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddRevenueTapped" />
                    </Frame.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Label Text="+" FontSize="20" FontAttributes="Bold" TextColor="#8A72D6" VerticalOptions="Center"/>
                        <Label Text="إضافة إيراد" FontSize="16" TextColor="Black" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- 2. Revenue Item Card (Example: Delivery) -->
                <Frame CornerRadius="12" BorderColor="#E0E0E0" BackgroundColor="White" Padding="15">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <!-- Edit Icon Button -->
                        <ImageButton Source="dotnet_bot.png" WidthRequest="20" HeightRequest="20" Grid.Column="0" VerticalOptions="Center" Clicked="OnEditRevenueTapped"/>

                        <!-- Name & Description -->
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,15,0">
                            <Label Text="توصيل" FontSize="18" FontAttributes="Bold" TextColor="Black" HorizontalOptions="End"/>
                            <Label Text="ال" FontSize="14" TextColor="Gray" HorizontalOptions="End" Margin="0,2,0,0"/>
                        </VerticalStackLayout>

                        <!-- Currency/Revenue Icon -->
                        <Label Text="💲" FontSize="20" Grid.Column="2" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>