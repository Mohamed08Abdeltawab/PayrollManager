<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PayrollManager.Views.PositionEditorPage"
             Title="إضافة/تعديل منصب"
             BackgroundColor="#F8F9FA"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*, Auto" Padding="20">
        <ScrollView Grid.Row="0">
            <Frame CornerRadius="12" BorderColor="#E0E0E0" BackgroundColor="White" Padding="20" Margin="0,10,0,0">
                <VerticalStackLayout Spacing="25" FlowDirection="RightToLeft">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="المنصب" TextColor="#9E9E9E" FontSize="14" HorizontalOptions="Start"/>
                        <Entry x:Name="NameEntry" FontSize="16" TextColor="Black" BackgroundColor="Transparent"/>
                        <BoxView HeightRequest="1" Color="#9E9E9E"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="الوصف" TextColor="#9E9E9E" FontSize="14" HorizontalOptions="Start"/>
                        <Entry x:Name="DescriptionEntry" FontSize="16" TextColor="Black" BackgroundColor="Transparent"/>
                        <BoxView HeightRequest="1" Color="#9E9E9E"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </ScrollView>
        <Button Grid.Row="1" Text="حفظ المنصب" BackgroundColor="#8A72D6" TextColor="White" CornerRadius="8" HeightRequest="45" Margin="0,0,0,10" Clicked="OnSaveClicked"/>
    </Grid>
</ContentPage>